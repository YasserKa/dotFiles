      "3": "´ëë",
      "4": "´éø",
      "5": "´üÁ",
      "6": "6",
      "7": "¯Àè",
      "8": "´çü",
      "9": "´ë¿"
    }
  },
  "clock": {
    "format-alt": "{:%m-%d}",
    "tooltip": false
  },
  "cpu": {
    "format-icons": "´ïø",
    "format": "{usage:>2}% {icon}",
  },
  "memory": {
    "format-icons": "´âë",
    "format": "{percentage:>2}% {icon}"
  },
  "battery": {
    "states": {
      "full": 100,
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "interval": 30,
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ¾░éä",
    "format-plugged": "{capacity}% ´çĞ",
    "format-full": "",
    "format-plugged-full": "",
    "format-alt": "{time} {icon}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },
  "network": {
    "interval": 2,
    "format-wifi": "{signalStrength}% ´ç½ {bandwidthDownBytes:>}",
    "format-ethernet": "¯¢ä {bandwidthDownBytes:>}",
    "tooltip-format": "{ifname} via {gwaddr} ¯¢ä",
    "format-linked": "{ifname} (No IP) ¯¢ä",
    "format-disconnected": "Disconnected ÔÜá",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },
  "bluetooth": {
    "format": "´èö {status}",
    "format-disabled": "", // an empty format will hide the module
    "format-connected-battery": "´èö",
    "format-connected": "´èö {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
