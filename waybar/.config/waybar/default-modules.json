{
  "sway/workspaces": {
    "disable-scroll": true,
    "warp-on-scroll": false,
    "format": "{icon}",
    "format-icons": {
      "0": "0",
      "1": "пВђ",
      "2": "пД†",
      "3": "пЙЙ",
      "4": "пВЫ",
      "5": "пБµ",
      "6": "6",
      "7": "оЈК",
      "8": "пЗБ",
      "9": "пЙ®"
    }
  },
  "clock": {
    "format-alt": "{:%m-%d}",
    "tooltip": false
  },
  "cpu": {
    "format": "{usage}% пЛЫ"
  },
  "memory": {
    "format-icons": "пГЙ",
    "format": "{}% {icon}"
  },
  "battery": {
    "states": {
      "full": 100,
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "interval": 30,
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% у∞ВД",
    "format-plugged": "{capacity}% пЗ¶",
    "format-full": "",
    "format-plugged-full": "",
    "format-alt": "{time} {icon}",
    "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
  },
  "network": {
    "interval": 2,
    "format-wifi": "{signalStrength}% пЗЂ {bandwidthDownBytes:>}",
    "format-ethernet": "ољД {bandwidthDownBytes:>}",
    "tooltip-format": "{ifname} via {gwaddr} ољД",
    "format-linked": "{ifname} (No IP) ољД",
    "format-disconnected": "Disconnected вЪ†",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },
  "bluetooth": {
    "format": "пКФ {status}",
    "format-disabled": "", // an empty format will hide the module
    "format-connected-battery": "пКФ",
    "format-connected": "пКФ {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
  },
  "pulseaudio": {
    "scroll-step": 1,
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}",
    "format-muted": "пС¶",
    "format-icons": {
      "headphone": "оєЩ",
      "hands-free": "оєЩ",
      "headset": "оєЩ",
      "phone": "пВХ",
      "phone-muted": "оіЧ",
      "portable": "пВХ",
      "car": "пЖє",
      "alsa_output.usb-DisplayLink_LAPDOCK_U3D2338310892-02.iec958-stereo": "оєЩ",
      "default": ["у∞ЦА", "у∞ХЊ"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "ignored-sinks": ["Easy Effects Sink"]
  },
  "custom/vpn": {
    "exec": "echo 'оЩ≤'",
    "interval": 5,
    // Tailscale is up & using an exit node
    "exec-if": "{ tailscale exit-node list | grep -q selected && tailscale status | grep -vq stopped; }"
  },
  "custom/mail": {
    "format": "{:>} пГ† ",
    "interval": "once",
    "exec": "$XDG_CONFIG_HOME/neomutt/bin/get_number_new_mail",
    "signal": 8
  },
  "custom/clock": {
    "format": "пЛ≤  {}",
    "interval": 1,
    "on-click": "$XDG_CONFIG_HOME/emacs/bin/org_clock go_to_entry",
    "exec-if": "bat /tmp/org_current_task 2>/dev/null",
    // get current task and the time since it got created
    "exec": "$XDG_CONFIG_HOME/emacs/bin/org_clock get_info [TIME_PLACEHOLDER]"
  },
  "custom/monitor": {
    "exec": "echo 'пБ∞'",
    "interval": 1,
    "exec-if": "cat /tmp/resources_monitor_disabled 2>/dev/null",
    "on-click": "rm /tmp/resources_monitor_disabled"
  },
  "custom/notifications": {
    "format": "{} ",
    "exec": "echo 'пЗґ'",
    "interval": 1,
    "exec-if": "[[ \"$(dunstctl is-paused)\" = \"true\" ]]"
  },
  "custom/notification-reddit": {
    "format": "пКБ {}",
    "exec": "$HOME/bin/notification-reddit",
    "signal": 5,
    "on-click": "$HOME/bin/notification-reddit open && rm /tmp/reddit_unread.json && pkill -SIGRTMIN+5 waybar"
  },
  "custom/notification-lemmy": {
    "format": "пБµ",
    "exec": "[[ -e '/tmp/lemmy_inbox.json' ]] && { cmp -s '/tmp/lemmy_inbox.json' \"$XDG_CACHE_HOME/lemmy_inbox.json\" || echo ' '; }",
    "signal": 6,
    "on-click": "xdg-open https://lemmy.world/inbox &&  mv -f '/tmp/lemmy_inbox.json' \"$XDG_CACHE_HOME/lemmy_inbox.json\" &&  pkill -SIGRTMIN+6 waybar"
  },
  "custom/notification-HN": {
    "format": "пЛ•",
    "exec": "[[ -e '/tmp/HN_inbox.json' ]] && { cmp -s '/tmp/HN_inbox.json' \"$XDG_CACHE_HOME/HN_inbox.json\" || echo ' '; }",
    "signal": 7,
    "on-click": "xdg-open https://news.ycombinator.com/threads?id=yasser_kaddoura &&  mv -f '/tmp/HN_inbox.json' \"$XDG_CACHE_HOME/HN_inbox.json\" && pkill -SIGRTMIN+7 waybar"
  },
  "custom/notification-canvas": {
    "format": "о†А",
    "interval": 30,
    "on-click": "$HOME/bin/canvas_utility open_assignment_link",
    "on-click-right": "$HOME/bin/canvas_utility open_file",
    "return-type": "json",
    "exec": "$HOME/bin/canvas_utility get_tooltip"
  },
  "tray": {
    "spacing": 10
  }
}
