#!/usr/bin/env bash

"$XDG_CONFIG_HOME/i3/set_i3_focus_on_window_activation_configuration" none 2

TEMPLATE="url"
case "$1" in
--template=*)
  TEMPLATE="${1#*=}"
  ;;
esac

encode_url() {
  # Reliable localization
  local LC_ALL=C
  # Go through each character
  for ((i = 0; i < ${#1}; i++)); do
    : "${1:i:1}"
    case "$_" in
    # Keep allowed characters
    [a-zA-Z0-9.~_-]) printf '%s' "$_" ;;
    # Encode disallowed characters
    *) printf '%%%02X' "'$_" ;;
    esac
  done
  printf '\n'
}

define() {
  word="$1"
  curl -fsSL "https://api.dictionaryapi.dev/api/v2/entries/en/$word" |
    jq -r '
  def clean: gsub("\\s+";" ") | gsub("^ +| +$";"");

  .[0] as $e
  | "Word: \($e.word)\n"
  + (
      $e.meanings
      | map(
          "Part of speech: \(.partOfSpeech)\n"
          + (
              .definitions
              | map(
                  "- Definition: \(.definition | clean)\n"
                  + (if (.example? and .example != null and .example != "") then
                       "  Example: \(.example | clean)\n"
                     else
                       ""
                     end)
                )
              | join("\n")
            )
        )
      | join("\n\n")
    )
'
}

URL_HOST="$(echo "$QUTE_URL" | awk -F '/' '{print $3}')"
# Encode it in case a title has ampersand "&"
QUTE_URL="$(encode_url "$QUTE_URL")"

# Create a frame to refile the URL
if [[ "$TEMPLATE" == "refile" ]]; then
  emacsclient --socket-name="$EMACS_ORG_SOCKET" --frame-parameters='((name . "floating") (width . 0.75) (height . 0.5))' --create-frame "org-protocol://capture?template=refile&title=$QUTE_TITLE&url=$QUTE_URL"
  exit 0
fi

# Store word definition in different way
if [[ "$URL_HOST" == "www.merriam-webster.com" ]]; then
  WORD="$(echo "$QUTE_URL" | awk -F '/' '{print $NF}')"
  emacsclient --socket-name="$EMACS_ORG_SOCKET" --no-wait "org-protocol://capture?template=word&url=$WORD&title=$(encode_url "$(define "$WORD")")"
  exit 0
fi

if org_capture "$QUTE_URL" "$QUTE_TITLE" "$TEMPLATE"; then
  echo ":message-info 'Note captured'" >>"$QUTE_FIFO"
else
  echo ":message-error 'Note not captured'" >>"$QUTE_FIFO"
fi
