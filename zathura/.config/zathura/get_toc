#!/usr/bin/env python
#
# Store a document's TOC with hierarchy metadata for folding
import pymupdf
import argparse

parser = argparse.ArgumentParser()
parser.add_argument("--document_path", help="Extract TOC from this file")
parser.add_argument("--toc_path", help="Store the TOC here")
args = parser.parse_args()
if args.document_path is None or args.toc_path is None:
    raise Exception

doc = pymupdf.open(args.document_path)
toc = doc.get_toc(simple=False)
n = len(toc)

end_id = [0] * n
for i in range(n):
    level = toc[i][0]
    j = i
    while j + 1 < n and toc[j + 1][0] > level:
        j += 1
    end_id[i] = j

# parent_id[i] = id of the nearest enclosing ancestor, or -1 if top-level
parent_id = [-1] * n
stack = []  # stack of ids on the current path
for i in range(n):
    level = toc[i][0]
    while stack and toc[stack[-1]][0] >= level:
        stack.pop()
    parent_id[i] = stack[-1] if stack else -1
    stack.append(i)

lines = []
for i, header in enumerate(toc):
    level, title, page = header[0], header[1], header[2]
    lines.append(
        "\t".join(
            [str(i), str(level), str(end_id[i]), str(parent_id[i]), title, str(page)]
        )
    )

with open(args.toc_path, "w") as f:
    f.write("\n".join(lines) + "\n")
