#!/usr/bin/env bash

INTERVAL=5
PAUSE_SECONDS=4

declare FILE_BASENAME SRC_FILE
FILE_BASENAME="${0##*/}"
FILE_BASENAME="${FILE_BASENAME%.*}"
SRC_FILE="$(mktemp -t "${FILE_BASENAME}_XXX")"
readonly SRC_FILE

declare FUNC_TYPE="time"
# Only allow alt-m when fkill() is used
enable_kill=0

[[ "$1" == "--kill" ]] && enable_kill=1

tmpdir="$(mktemp -d)"
pause_file="$tmpdir/pause_until"
reload_file="$tmpdir/last_reload_at"

gen_cands() {
	case "$FUNC_TYPE" in
	"time") grc --colour=on ps -A -o user,ppid,pid,etime,%mem,args --sort +etime | sed 1d ;;
	"mem") grc --colour=on ps -A -o user,ppid,pid,etime,%mem,args --sort -%mem | sed 1d ;;
	esac
}

#######################################
# Save functions and variables used by Fzf shells
# Globals:
#   SRC_FILE
#######################################
save() {
	declare -p SRC_FILE FUNC_TYPE >|"$SRC_FILE"
	declare -f gen_cands save >>"$SRC_FILE"
}

save

cleanup() {
	rm -rf "$tmpdir"
}
trap cleanup EXIT

printf '0\n' >"$pause_file"
printf '0\n' >"$reload_file"

SOCKET_PATH="/tmp/fzf_fps.sock"

fzf --ansi --multi --track --id-nth 3,-1 \
	--preview-window=down,3,wrap-word,border-none,hidden \
	--listen "$SOCKET_PATH" \
	--prompt "next update in ?s > " \
	--preview 'ps -F {3} | sed 1d | grep -q . && grc --colour=on ps -F {3} | sed 1d || echo "no {3} found"' \
	--bind "ctrl-alt-t:execute-silent(source $SRC_FILE; FUNC_TYPE=time; save)+reload(source $SRC_FILE; gen_cands)" \
	--bind "ctrl-alt-m:execute-silent(source $SRC_FILE; FUNC_TYPE=mem; save)+reload(source $SRC_FILE; gen_cands)" \
	--bind "ctrl-r:reload-sync(source $SRC_FILE; gen_cands)" \
	--bind "alt-m:execute-silent(kill {+3})" \
	--bind 'alt-t:change-preview-window(down|hidden)' \
	--bind "start:reload-sync(source $SRC_FILE; gen_cands)" \
	--bind "focus:execute-silent(sh -c 'now=\$(date +%s); last_reload=\$(cat \"$reload_file\" 2>/dev/null || echo 0); if [ \$((now - last_reload)) -ge 1 ]; then echo \$((now + $PAUSE_SECONDS)) > \"$pause_file\"; fi')" |
	grep . | awk '{print $3}' &

curl -s localhost --unix-socket "$SOCKET_PATH" http -d "unbind(alt-m)"
((enable_kill == 1)) && curl -s localhost --unix-socket "$SOCKET_PATH" http -d "rebind(alt-m)"

fzf_pid=$!

next_refresh=$(($(date +%s) + INTERVAL))

while kill -0 "$fzf_pid" 2>/dev/null; do
	now=$(date +%s)
	pause_until=$(cat "$pause_file" 2>/dev/null || echo 0)

	if [ "$pause_until" -gt "$next_refresh" ]; then
		next_update="$pause_until"
	else
		next_update="$next_refresh"
	fi

	remaining=$((next_update - now))
	[ "$remaining" -lt 0 ] && remaining=0

	curl -s localhost --unix-socket "$SOCKET_PATH" http \
		-d "change-prompt(${remaining}>)" >/dev/null

	# Unbind ctrl-m right before candidates update to avoid accidents
	if [ "$remaining" -eq 1 ]; then
		curl -s localhost --unix-socket "$SOCKET_PATH" http -d "unbind(ctrl-m)"
		((enable_kill == 1)) && curl -s localhost --unix-socket "$SOCKET_PATH" http -d "unbind(alt-m)"
	elif [ "$remaining" -gt 1 ]; then
		curl -s localhost --unix-socket "$SOCKET_PATH" http -d "rebind(ctrl-m)"
		((enable_kill == 1)) && curl -s localhost --unix-socket "$SOCKET_PATH" http -d "rebind(alt-m)"
	fi

	if [ "$remaining" -eq 0 ]; then
		printf '%s\n' "$now" >"$reload_file"
		curl -s localhost --unix-socket "$SOCKET_PATH" http -d "reload-sync(source $SRC_FILE; gen_cands)" >/dev/null
		next_refresh=$((now + INTERVAL))
	fi

	sleep 1
done &

wait "$fzf_pid" 2>/dev/null || true
